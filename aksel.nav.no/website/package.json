{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "description": "Aksel.nav.no website",
  "author": "Aksel | Nav designsystem team",
  "scripts": {
    "dev": "next | pino-pretty --messageKey=message",
    "build": "concurrently \"yarn workspace playroom build:playroom\" \"yarn next build\" \"yarn update:rss\" && yarn cp:assets",
    "start": "cd .next/standalone/aksel.nav.no/website && PORT=3000 HOSTNAME=0.0.0.0 node server.js",
    "e2e:dev": "yarn generate-testpaths && playwright test --ui",
    "e2e:docker": "yarn generate-testpaths && playwright test",
    "update:rss": "yarn tsx --env-file-if-exists=.env ./scripts/generate-rss-feed",
    "update:props": "yarn tsx --env-file-if-exists=.env ./scripts/update-props",
    "update:eksempler": "yarn tsx --env-file-if-exists=.env ./scripts/update-examples/update-sanity",
    "validate:eksempler": "yarn tsx ./scripts/update-examples/validate",
    "update:changelog": "yarn tsx --env-file-if-exists=.env ./scripts/changelog",
    "update:stats": "yarn tsx --env-file-if-exists=.env ./scripts/update-stats/update-stats",
    "update:sanity": "yarn update:props && yarn update:eksempler && yarn update:changelog && yarn update:stats",
    "analyze": "cross-env ANALYZE=true yarn build",
    "test": "vitest run -c config/vitest.config.ts",
    "test:watch": "vitest watch -c config/vitest.config.ts",
    "playwright": "playwright test",
    "backup": "yarn tsx --env-file-if-exists=.env scripts/backup.ts",
    "generate-testpaths": "yarn tsx --env-file-if-exists=.env ./scripts/generate-testpaths.ts",
    "update:sanity-schema": "cd ./sanity && yarn sanity schema extract --workspace default --path ./sanity-schema.json && yarn sanity typegen generate",
    "update:sanity-manifest": "cd ./sanity && yarn sanity schema deploy --workspace default --manifest-dir ../public/studio/static",
    "cp:playroom": "copyfiles -E -u 3 '../playroom/dist/sandbox/**' public/",
    "cp:static": "copyfiles -E -u 1 '.next/static/**' .next/standalone/aksel.nav.no/website/.next/",
    "cp:public": "copyfiles -E 'public/**' .next/standalone/aksel.nav.no/website/",
    "cp:assets": "yarn cp:playroom && yarn cp:public && yarn cp:static"
  },
  "dependencies": {
    "@navikt/analytics-types": "0.0.7",
    "@navikt/next-logger": "4.4.1",
    "@navikt/oasis": "3.2.1",
    "@neshca/cache-handler": "1.9.0",
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "7.21.0",
    "@sanity/code-input": "7.1.0",
    "@sanity/color-input": "6.0.4",
    "@sanity/image-url": "2.1.1",
    "@sanity/locale-nb-no": "1.1.33",
    "@sanity/preview-url-secret": "4.0.5",
    "@sanity/table": "2.0.1",
    "@sanity/vision": "5.22.0",
    "@slack/web-api": "^7.8.0",
    "codesandbox-import-utils": "^2.2.3",
    "date-fns": "^4.0.0",
    "fuse.js": "^7.3.0",
    "isomorphic-dompurify": "2.26.0",
    "jscodeshift": "17.3.0",
    "lodash": "4.18.1",
    "lz-string": "^1.5.0",
    "next": "16.2.6",
    "next-logger": "^5.0.2",
    "next-sanity": "12.3.0",
    "next-themes": "^0.4.6",
    "node-cache": "^5.1.2",
    "pino": "^8.21.0",
    "prism-react-renderer": "^2.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^9.0.1",
    "react-responsive-masonry": "2.2.0",
    "react-rx": "^2.1.3",
    "react-snowfall": "^2.4.0",
    "remark-gfm": "^4.0.0",
    "rxjs": "^7.8.2",
    "sanity": "5.22.0",
    "sanity-plugin-iframe-pane": "5.0.11",
    "sanity-plugin-media": "4.1.1",
    "sanity-plugin-references": "1.0.1",
    "semver": "^7.7.2",
    "server-only": "^0.0.1",
    "sharp": "0.33.5",
    "styled-components": "^6.0.0",
    "swr": "^2.4.1",
    "tinycolor2": "^1.6.0",
    "typescript-cookie": "^1.0.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@babel/core": "^7.19.0",
    "@babel/parser": "^7.27.5",
    "@babel/traverse": "^7.27.4",
    "@google-cloud/bigquery": "^8.3.1",
    "@next/bundle-analyzer": "16.2.6",
    "@next/eslint-plugin-next": "16.2.6",
    "@playwright/test": "1.60.0",
    "@portabletext/block-tools": "^5.1.1",
    "@portabletext/markdown": "^1.2.0",
    "@sanity/blueprints": "0.16.0",
    "@sanity/export": "6.1.0",
    "@sanity/functions": "1.3.1",
    "@sanity/schema": "5.22.0",
    "@types/jscodeshift": "17.3.0",
    "@types/jsdom": "^27.0.0",
    "@types/lodash": "4.17.20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@types/showdown": "^2.0.6",
    "@types/umami": "^2.10.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "jsdom": "29.1.1",
    "json5": "2.2.1",
    "pino-pretty": "^10.0.0",
    "rss": "^1.2.2",
    "showdown": "^2.1.0",
    "tsx": "^4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
