{
  "name": "@navikt/aksel",
  "version": "8.14.0",
  "description": "Aksel command line interface. Codemods and other utilities for Aksel users.",
  "author": "Aksel | Nav designsystem team",
  "license": "MIT",
  "keywords": [
    "Commandline",
    "CLI",
    "CDN",
    "Codemods"
  ],
  "files": [
    "dist",
    "!dist/**/tests"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "generate-version": "node -e \"const fs=require('fs');const v=require('./package.json').version;fs.writeFileSync('src/version.ts','export const VERSION = \\\"'+v+'\\\";\\n')\"",
    "build": "yarn clean && yarn generate-version && tsc -p tsconfig.json",
    "dev": "yarn generate-version && tsc --watch -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "bin": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./migrations": {
      "import": "./dist/migrations-config.js",
      "types": "./dist/migrations-config.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navikt/aksel.git",
    "directory": "@navikt/aksel"
  },
  "homepage": "https://aksel.nav.no/grunnleggende/kode/kommandolinje",
  "bugs": {
    "url": "https://github.com/navikt/aksel/issues"
  },
  "dependencies": {
    "@navikt/ds-css": "^8.14.0",
    "@navikt/ds-tokens": "^8.14.0",
    "chalk": "5.6.2",
    "cli-progress": "3.12.0",
    "clipboardy": "5.3.1",
    "commander": "15.0.0",
    "enquirer": "2.4.1",
    "fast-glob": "3.3.3",
    "figlet": "1.11.0",
    "is-git-clean": "1.1.0",
    "jscodeshift": "17.3.0",
    "jscodeshift-add-imports": "1.0.11",
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@types/cli-progress": "3.11.6",
    "@types/is-git-clean": "1.1.2",
    "@types/jscodeshift": "17.3.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
