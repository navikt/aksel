{
  "name": "playroom",
  "scripts": {
    "start": "yarn build:config && yarn sync-imports && playroom start",
    "build:playroom": "yarn build:config && yarn sync-imports && playroom build",
    "build:config": "tsc --project ./tsconfig.json",
    "sync-imports": "tsx --tsconfig ./scripts/tsconfig.json ./scripts/generate-imports.ts"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "babel-loader": "^9.1.3",
    "babel-plugin-preval": "^5.1.0",
    "playroom": "^1.2.1",
    "style-loader": "^4.0.0",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "react": "19.2.4"
  }
}
