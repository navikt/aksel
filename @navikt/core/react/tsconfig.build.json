{
  "extends": "../../../tsconfig.build.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "outDir": "./cjs",
    "lib": ["es2020", "dom", "dom.iterable"],
    "moduleResolution": "node",
    "module": "commonjs",
    "noImplicitAny": false,
    "declaration": true,
    "sourceMap": true,
    "types": ["@types/node"]
  },
  "include": ["./src"],
  "exclude": [
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.test-d.ts",
    "./src/**/*.stories.tsx",
    "./src/**/renderStoriesForChromatic.tsx"
  ]
}
