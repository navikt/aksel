{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "javascript": {
    "jsxRuntime": "reactClassic"
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "maxSize": 2000000,
    "includes": [
      "**",
      "!**/public",
      "!**/codemod/**/*.js",
      "!**/modal/dialog-polyfill.ts",
      "!**/_sanity/query-types.ts",
      "!**/component-names.generated.ts",
      "!**/transforms/**/*.input.*",
      "!**/transforms/**/*.output.*"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "style": {
        "useSelfClosingElements": "off",
        "useDefaultParameterLast": "off",
        "noUselessElse": "error",
        "useConsistentObjectDefinitions": "error",
        "useConsistentArrayType": "error",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noVar": "off",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": [
              "info",
              "warn",
              "error",
              "group",
              "groupEnd",
              "table",
              "assert",
              "countReset",
              "count",
              "dir",
              "time",
              "timeEnd",
              "timeStamp"
            ]
          }
        }
      },
      "nursery": {
        "noShadow": "error"
      },
      "complexity": {
        "noForEach": "off",
        "useArrowFunction": "off",
        "noImportantStyles": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["aksel.nav.no/website/pages/eksempler/**"],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.stories.ts", "**/*.stories.tsx", "scripts/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
